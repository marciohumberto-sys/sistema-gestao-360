              <div>\n1670:                                             <div style={{ fontWeight: 600, color: '#334155', fontSize: '0.9rem' }}>Imprime no laudo</div>\n1671:                                             <div style={{ fontSize: '0.8rem', color: '#64748b' }}>O exame será exibido no laudo do paciente.</div>\n1672:                                         </div>\n1673:                                     </label>\n1674:                                 </div>\n1675:                             </div>\n1676:                         </div>\n1677: \n1678:                         <div style={{ padding: '16px 32px', borderTop: '1px solid #e2e8f0', background: '#f8fafc', display: 'flex', justifyContent: 'flex-end', gap: '12px' }}>\n1679:                             <button \n1680:                                 className=\"unsaved-btn-neutral\" \n1681:                                 onClick={handleCloseModal} \n1682:                                 disabled={actionLoading}\n1683:                             >\n1684:                                 Cancelar\n1685:                             </button>\n1686:                             <button \n1687:                                 className=\"lab-btn-primary\" \n1688:                                 style={{ \n1689:                                     display: 'inline-flex', alignItems: 'center', justifyContent: 'center', \n1690:                                     minWidth: '160px', height: '46px', padding: '0 22px', boxSizing: 'border-box',\n1691:                                     borderRadius: '8px', border: 'none', \n1692:                                     background: '#3b82f6', color: '#fff', fontWeight: 600, cursor: 'pointer', textAlign: 'center'\n1693:                                 }} \n1694:                                 onClick={handleSaveExam} \n1695:                                 disabled={actionLoading}\n1696:                             >\n1697:                                 {actionLoading ? (\n1698:                                     <span style={{ display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: '9px', width: '100%', lineHeight: 1 }}>\n1699:                                         <Loader2 size={18} className=\"spin\" style={{ flex: '0 0 18px' }} />\n1700:                                         <span>{editingExam ? 'Salvando...' : 'Cadastrando...'}</span>\n1701:                                     </span>\n1702:                                 ) : (\n1703:                                     <span>{editingExam ? 'Salvar exame' : 'Cadastrar exame'}</span>\n1704:                                 )}\n1705:                             </button>\n1706:                         </div>\n1707:                     </div>\n1708:                 </div>\n1709:             )}\n1710: \n1711:             {/* Modal Alterações Não Salvas */}\n1712:             {showUnsavedModal && (\n1713:                 <div className=\"unsaved-result-modal-overlay\" role=\"dialog\" aria-modal=\"true\" style={{ zIndex: 9999 }}>\n1714:                     <div className=\"unsaved-result-modal\">\n1715:                         <div className=\"unsaved-result-modal-header\">\n1716:                             <div className=\"unsaved-result-modal-icon\">\n1717:                                 <AlertTriangle size={24} />\n1718:                             </div>\n1719:                             <div>\n1720:                                 <h2 className=\"unsaved-result-modal-title\">Descartar alterações?</h2>\n1721:                             </div>\n1722:                         </div>\n1723:                         <div className=\"unsaved-result-modal-body\">\n1724:                             <p>As alterações realizadas não foram salvas.</p>\n1725:                         </div>\n1726:                         <div className=\"unsaved-result-modal-footer\" style={{ display: 'flex', gap: '12px', justifyContent: 'flex-end' }}>\n1727:                             <button \n1728:                                 className=\"unsaved-btn-neutral\" \n1729:                                 style={{\n1730:                                     display: 'inline-flex', alignItems: 'center', justifyContent: 'center',\n1731:                                     minWidth: '220px', height: '46px', padding: '0 22px', boxSizing: 'border-box',\n1732:                                     borderRadius: '10px', border: '1px solid #cbd5e1', \n1733:                                     background: 'transparent', color: '#475569', fontWeight: 600, cursor: 'pointer', textAlign: 'center',\n1734:                                     transition: 'background-color 0.2s'\n1735:                                 }}\n1736:                                 onMouseEnter={e => e.target.style.backgroundColor = '#f1f5f9'}\n1737:                                 onMouseLeave={e => e.target.style.backgroundColor = 'transparent'}\n1738:                                 onClick={() => setShowUnsavedModal(false)}\n1739:                             >\n1740:                                 Continuar editando\n1741:                             </button>\n1742:                             <button \n1743:                                 className=\"lab-btn-danger\" \n1744:                                 style={{\n1745:                                     display: 'inline-flex', alignItems: 'center', justifyContent: 'center', gap: '8px',\n1746:                                     minWidth: '220px', height: '46px', padding: '0 22px', boxSizing: 'border-box',\n1747:                                     borderRadius: '10px', border: 'none', \n1748:                                     background: '#ef4444', color: '#fff', fontWeight: 600, cursor: 'pointer', textAlign: 'center',\n1749:                                     transition: 'background-color 0.2s'\n1750:                                 }}\n1751:                                 onMouseEnter={e => e.currentTarget.style.backgroundColor = '#dc2626'}\n1752:                                 onMouseLeave={e => e.currentTarget.style.backgroundColor = '#ef4444'}\n1753:                                 onClick={confirmDiscardChanges}\n1754:                             >\n1755:                                 <Trash2 size={18} />\n1756:                                 <span>Descartar alterações</span>\n1757:                             </button>\n1758:                         </div>\n1759:                     </div>\n1760:                 </div>\n1761:             )}\n1762:         </div>\n1763:     );\n1764: };\n1765: \n1766: export default LaboratorioConfiguracoes;\n1767: \nThe above content does NOT show the entire file contents. If you need to view any lines of the file which were not shown to complete your task, call this tool again to view those lines.\n"
